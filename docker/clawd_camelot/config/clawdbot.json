{
  "$schema": "https://clawd.bot/schema/config.json",
  "version": "1.0.0",

  "gateway": {
    "mode": "local",
    "port": 18789,
    "host": "0.0.0.0",
    "auth": {
      "required": false,
      "tokenFile": "~/.clawdbot/gateway.token"
    }
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "token": "${TELEGRAM_BOT_TOKEN}",
      "options": {
        "allowGroups": true,
        "allowDMs": true,
        "parseMode": "Markdown",
        "polling": {
          "timeout": 30,
          "limit": 100
        }
      },
      "commands": [
        {
          "command": "start",
          "description": "Start the bot and show help"
        },
        {
          "command": "help",
          "description": "Show available commands"
        },
        {
          "command": "status",
          "description": "Check bot and connection status"
        },
        {
          "command": "id",
          "description": "Show your Telegram user ID"
        },
        {
          "command": "athena",
          "description": "Query AWS Athena data warehouse"
        },
        {
          "command": "sentinel",
          "description": "OpenSearch fraud detection AI"
        },
        {
          "command": "sentinel_athena",
          "description": "Athena fraud detection AI"
        },
        {
          "command": "excalibur",
          "description": "Cross-database investigation AI"
        },
        {
          "command": "msbo_cs",
          "description": "Customer service investigation"
        },
        {
          "command": "king_arthur",
          "description": "Multi-agent investigation orchestrator"
        },
        {
          "command": "aws",
          "description": "AWS operations workflow"
        },
        {
          "command": "update_schema",
          "description": "Sync Athena schema documentation"
        }
      ],
      "webhooks": {
        "enabled": false,
        "url": "${TELEGRAM_WEBHOOK_URL}",
        "notes": "Enable for production with HTTPS endpoint"
      }
    },
    "whatsapp": {
      "enabled": false,
      "notes": "Enable after QR pairing via: docker compose run --rm clawd-cli channels login"
    },
    "discord": {
      "enabled": false,
      "token": "${DISCORD_BOT_TOKEN}",
      "notes": "Add Discord bot token if needed"
    }
  },

  "agents": {
    "default": "athena-claude-wrapper",
    "available": {
      "athena-claude-wrapper": {
        "type": "custom",
        "path": "/home/node/agents/athena-claude-wrapper.ts",
        "description": "Athena data queries via Claude Code CLI"
      }
    }
  },

  "security": {
    "allowlist": {
      "enabled": true,
      "file": "/home/node/config/allowlist.json"
    },
    "rateLimit": {
      "enabled": true,
      "maxRequests": 30,
      "windowSeconds": 60
    },
    "messageRetention": {
      "enabled": false,
      "days": 7
    }
  },

  "logging": {
    "level": "info",
    "format": "json",
    "file": "~/.clawdbot/logs/gateway.log"
  },

  "workspace": {
    "path": "/home/node/workspace",
    "contextFiles": ["CLAUDE.md", ".claude/PROJECT_INDEX.json"]
  }
}
