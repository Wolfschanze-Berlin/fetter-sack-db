# =============================================================================
# Clawd Camelot - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Gateway Settings
# -----------------------------------------------------------------------------
CLAWD_GATEWAY_PORT=18789

# -----------------------------------------------------------------------------
# Telegram Bot Configuration
# -----------------------------------------------------------------------------
# Create a bot via @BotFather on Telegram and paste the token here
# Format: 123456789:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Anthropic/Claude API
# -----------------------------------------------------------------------------
# Your Anthropic API key for Claude Code
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# AWS Credentials (General)
# -----------------------------------------------------------------------------
# Default AWS credentials for S3 and general AWS operations
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-southeast-1

# -----------------------------------------------------------------------------
# AWS Athena Credentials
# -----------------------------------------------------------------------------
# Separate credentials for Athena queries (if different from general AWS)
# These connect to the ap-northeast-1 region for Athena
ATHENA_ACCESS_KEY=
ATHENA_ACCESS_KEY_SECRET=
ATHENA_REGION=ap-northeast-1

# -----------------------------------------------------------------------------
# S3 Output Configuration
# -----------------------------------------------------------------------------
# Bucket for storing large query results
S3_OUTPUT_BUCKET=services-athena-query-output-s3-9707

# -----------------------------------------------------------------------------
# Optional: Brave Search API
# -----------------------------------------------------------------------------
# For web search functionality in the AI agent
# Get from: https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=
