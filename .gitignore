# Environment files (contain secrets)
.env.*
!.env.example
# .env is committed — contains only COMPOSE_PROFILES (no secrets)

# Docker volumes & build artifacts
pg_data/
db/pg/cache/*
!db/pg/cache/*.sql
!db/pg/cache/*.sh

# Logs
*.log
logs/

# DuckDB / Parquet local cache
*.duckdb
*.duckdb.wal
*.parquet

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Compiled binaries
*.exe
*.dll
*.so
*.dylib

# OMC state (claude tooling)
.omc/
.mcp.json
